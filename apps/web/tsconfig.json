{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@dfa/types": ["../../packages/types/src/index.ts"],
      "@dfa/logic": ["../../packages/logic/src/index.ts"],
      "@dfa/supabase-client": ["../../packages/supabase-client/src/index.ts"]
    }
  },
  "include": ["src"]
}
